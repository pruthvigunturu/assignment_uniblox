      "description": "Endpoints for managing shopping cart - Add items and retrieve cart contents",
      "item": [
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user1\",\n  \"productId\": \"prod1\",\n  \"quantity\": 2,\n  \"price\": 10.0\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart/add",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "add"]
            },
            "description": "Add an item to the user's cart. If item already exists, quantity will be updated instead of adding duplicate."
          },
          "response": [
            {
              "name": "Success (200 OK)",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"user1\",\n  \"productId\": \"prod1\",\n  \"quantity\": 2,\n  \"price\": 10.0\n}"
                },
                "url": {
                  "raw": "http://localhost:8080/api/cart/add",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8080",
                  "path": ["api", "cart", "add"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "plain",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain;charset=UTF-8"
                }
