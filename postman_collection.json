            "url": {
              "raw": "http://localhost:8080/api/checkout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "checkout"]
            },
            "description": "Process checkout and place an order. Validates discount code if provided. Clears the cart after successful order placement. Generates a discount code for every 5th order."
